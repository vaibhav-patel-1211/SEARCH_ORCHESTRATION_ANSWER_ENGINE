# IPython
profile_default/
ipython_config.py

# pyenv
#   For a library or binary, you should probably not check in .python-version
.python-version

# pipenv
#   According to pypa/pipenv#1185, it is recommended to check in Pipfile.lock into source control.
#   However, in case of collaboration, if you have platform-specific dependencies or dependencies
#   having no wheels, you might want to keep it out of source control.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, it is generally recommended to include poetry.lock in version control.
#poetry.lock

# pdm
#   Similar to Pipfile.lock, it is generally recommended to include pdm.lock in version control.
#pdm.lock

# PEP 582; used by e.g. pdm
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

