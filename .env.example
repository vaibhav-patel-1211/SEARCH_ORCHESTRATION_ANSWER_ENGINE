# LLM API Keys
# If using NVIDIA AI Endpoints (used in current requirements/implementation)
NVIDIA_API_KEY=your_nvidia_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Database & Vector Store
# MongoDB Atlas URI (Vector Search enabled)
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/
MONGO_LOCAL_URI=mongodb://localhost:27017/

# HuggingFace Token (for local embeddings/reranking)
HF_TOKEN=your_huggingface_token_here

# Authentication
# Use a long, random string for the secret key
SECRET_KEY=your_super_secret_random_string_here
ALGORITHM=HS256

# Secure Code Execution Sandbox (E2B)
E2B_API_KEY=your_e2b_api_key_here

# Caching (Valkey/Redis)
VALKEY_HOST=localhost
VALKEY_PORT=6380
VALKEY_PASSWORD=

# App Configuration
APP_NAME="Horizon: Search Orchestration"
DEBUG=true
